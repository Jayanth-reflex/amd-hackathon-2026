# llama.cpp-server env — MI300X portable serving path
# Loaded by docker-compose.yml service `llamacpp`.
# All flags here MUST match CLAUDE.md §D.2.

# CRITICAL: -ctk bf16 -ctv bf16 (NOT default f16) — Qwen3.6 is natively bf16,
# and f16 KV measurably degrades perplexity.
CTK=bf16
CTV=bf16

# Model paths (BF16 reference for production on MI300X; Q4_K_M for M4 failover)
MODEL=/gguf/Qwen3.6-35B-A3B-Domain-Aggressive-BF16.gguf
MMPROJ=/gguf/mmproj-Qwen3.6-35B-A3B-Domain-Aggressive-f16.gguf

# Server
PORT=8001
HOST=0.0.0.0
CTX=131072
NGL=99
PARALLEL=8
JINJA=1
FLASH_ATTN=1
