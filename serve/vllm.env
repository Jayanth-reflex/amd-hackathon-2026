# vLLM serving env — MI300X (gfx942) production
# Loaded by docker-compose.yml service `vllm`.
# All flags here MUST match CLAUDE.md §D.1.

# AITER (mandatory for vLLM on MI300X)
VLLM_ROCM_USE_AITER=1
VLLM_ROCM_USE_AITER_MOE=1
VLLM_ROCM_USE_AITER_FP4BMM=0     # MI300X (gfx942) does NOT support FP4 — must disable
HIP_FORCE_DEV_KERNARG=1
TORCH_BLAS_PREFER_HIPBLASLT=1
NCCL_MIN_NCHANNELS=112

# HF + cache
HF_HOME=/data/hf
HF_HUB_ENABLE_HF_TRANSFER=1

# Model — Qwen3.6-35B-A3B Aggressive
MODEL=Jayanth/Qwen3.6-35B-A3B-Domain-Aggressive

# Server
PORT=8000
TENSOR_PARALLEL_SIZE=1
MAX_MODEL_LEN=131072
GPU_MEMORY_UTILIZATION=0.55      # leaves headroom for llama.cpp co-residence
KV_CACHE_DTYPE=fp8
ENFORCE_EAGER=1                   # compiled mode shows no gain on ROCm MoE in current builds

# Reasoning + tools
REASONING_PARSER=qwen3
ENABLE_AUTO_TOOL_CHOICE=1
TOOL_CALL_PARSER=hermes

# Caching
ENABLE_PREFIX_CACHING=1

# Speculative decoding (Qwen3.6 MTP)
SPECULATIVE_ALGO=NEXTN
SPECULATIVE_NUM_STEPS=3
SPECULATIVE_EAGLE_TOPK=1
SPECULATIVE_NUM_DRAFT_TOKENS=4
